<form>
    <label name="payment"/>
    <field name="payment"/>
    <label name="reason"/>
    <field name="reason"/>
    <label name="currency"/>
    <field name="currency"/>
    <label name="company"/>
    <field name="company"/>

    <notebook>
        <page name="redsys_error_code" string="Error">
            <label name="redsys_error_code"/>
            <field name="redsys_error_code" xexpand="0" xalign="0"/>
            <newline/>
            <label name="redsys_error_message"/>
            <field name="redsys_error_message" colspan="3"/>
        </page>
    </notebook>

    <label name="state"/>
    <field name="state"/>
    <group col="-1" colspan="2" id="buttons">
        <button name="draft"/>
        <button name="succeed"/>
        <button name="fail"/>
    </group>
</form>
